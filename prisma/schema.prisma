  conversionScore      Float    @default(0)
  geoReadinessScore    Float    @default(0)
  publicationReadinessScore Float @default(0)
  overallScore         Float    @default(0)
  details              String? // JSON with detailed analysis per dimension
  recommendations      String? // JSON array of recommendations
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

