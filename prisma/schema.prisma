  // Author
  authorId        String
  // Metadata
  isPinned        Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([authorId])
  @@index([deletedAt])
  @@map("internal_notes")
}

// ============================================================================
// Phase 10: Project Management Integrations
// ============================================================================

model PMIntegration {
  id              String                 @id @default(uuid())
  organizationId  String
  projectId       String?
  // Provider
  provider        PMIntegrationProvider
  status          PMIntegrationStatus    @default(DISCONNECTED)
  // Connection
  apiEndpoint     String?
  apiKeyEncrypted String?                // Encrypted API key
  // Configuration
  projectMapping  String?                // JSON: { externalProjectId, externalProjectKey }
  ownerMapping    String?                // JSON: { userId: externalUserId }
  fieldMapping    String?                // JSON: custom field mappings
  // Sync
