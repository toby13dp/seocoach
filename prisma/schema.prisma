// ============================================================================
// Prisma Schema — AI-Driven SEO Automation Platform (Phase 1)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum Role {
  PLATFORM_ADMIN
  ORG_OWNER
  AGENCY_OWNER
  SEO_MANAGER
  CONTENT_MANAGER
  EDITOR
  DEVELOPER
  CLIENT
  READ_ONLY
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionEffort {
  MINIMAL
  LOW
  MEDIUM
  HIGH
}

enum ActionItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum PermissionCategory {
  MANAGE_USERS
  MANAGE_PROJECTS
  MANAGE_CONTENT
  MANAGE_SETTINGS
  VIEW_ANALYTICS
  MANAGE_INTEGRATIONS
  MANAGE_PUBLISHING
  VIEW_REPORTS
}

// ============================================================================
// NextAuth.js v4 Models
// ============================================================================

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// User
// ============================================================================

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  name                    String?
  hashedPassword          String?
  emailVerified           DateTime?
  image                   String?
  locale                  String    @default("nl-NL")
  timezone                String?
  automationLevel         String?
  notificationPreferences String?
  privacyPreferences      String?
  deletedAt               DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships OrganizationMembership[]
  invitations Invitation[]             @relation("InvitedBy")
  settings    UserSettings?
  auditLogs   AuditLog[]
  jobs        Job[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

// ============================================================================
// Organization
// ============================================================================

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  website     String?
  logoUrl     String?
  locale      String    @default("nl-NL")
  settings    String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships OrganizationMembership[]
  invitations Invitation[]
  clients     Client[]
  projects    Project[]
  auditLogs   AuditLog[]

  @@index([slug])
  @@index([deletedAt])
  @@map("organizations")
}

// ============================================================================
// OrganizationMembership
// ============================================================================

model OrganizationMembership {
  id             String    @id @default(uuid())
  userId         String
  organizationId String
  role           Role      @default(READ_ONLY)
  invitedAt      DateTime?
  acceptedAt     DateTime?
  deletedAt      DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([role])
  @@index([deletedAt])
  @@map("organization_memberships")
}

// ============================================================================
// Invitation
// ============================================================================

model Invitation {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           Role      @default(READ_ONLY)
  token          String    @unique
  invitedBy      String
  expiresAt      DateTime
  acceptedAt     DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
  @@index([token])
  @@map("invitations")
}

// ============================================================================
// Client
// ============================================================================

model Client {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  slug           String
  description    String?
  website        String?
  industry       String?
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("clients")
}

// ============================================================================
// Project
// ============================================================================

model Project {
  id                  String        @id @default(uuid())
  organizationId      String
  clientId            String?
  name                String
  slug                String
  description         String?
  websiteUrl          String?
  status              ProjectStatus @default(ACTIVE)
  settings            String?
  onboardingCompleted Boolean       @default(false)
  onboardingStep      Int           @default(0)
  deletedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now()) @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  domains      Domain[]
  locations    Location[]
  brandProfile BrandProfile?
  jobs         Job[]
  auditLogs    AuditLog[]
  actionItems  ActionItem[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([deletedAt])
  @@map("projects")
}

// ============================================================================
// Domain
// ============================================================================

model Domain {
  id                 String    @id @default(uuid())
  projectId          String
  domain             String
  isPrimary          Boolean   @default(false)
  verifiedAt         DateTime?
  verificationMethod String?
  deletedAt          DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, domain])
  @@index([projectId])
  @@index([deletedAt])
  @@map("domains")
}

// ============================================================================
// Location
// ============================================================================

model Location {
  id         String    @id @default(uuid())
  projectId  String
  name       String
  address    String?
  city       String?
  postalCode String?
  country    String?
  phone      String?
  email      String?
  latitude   Float?
  longitude  Float?
  deletedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([deletedAt])
  @@map("locations")
}

// ============================================================================
// BrandProfile
// ============================================================================

model BrandProfile {
  id                    String    @id @default(uuid())
  projectId             String
  brandName             String?
  description           String?
  products              String? // JSON
  services              String? // JSON
  audiences             String? // JSON
  regions               String? // JSON
  toneOfVoice           String?
  addressPreference     String?
  preferredTerminology  String? // JSON
  prohibitedTerminology String? // JSON
  allowedClaims         String? // JSON
  prohibitedClaims      String? // JSON
  proofPoints           String? // JSON
  certifications        String? // JSON
  contactInformation    String? // JSON
  conversionGoals       String? // JSON
  editorialRules        String? // JSON
  disclaimers           String? // JSON
  locale                String    @default("nl-NL")
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId])
  @@index([projectId])
  @@index([deletedAt])
  @@map("brand_profiles")
}

// ============================================================================
// Permission
// ============================================================================

model Permission {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  category    PermissionCategory

  rolePermissions RolePermission[]

  @@index([category])
  @@map("permissions")
}

// ============================================================================
// RolePermission
// ============================================================================

model RolePermission {
  id           String @id @default(uuid())
  role         Role
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
  @@map("role_permissions")
}

// ============================================================================
// Job
// ============================================================================

model Job {
  id          String    @id @default(uuid())
  projectId   String
  type        String
  status      JobStatus @default(PENDING)
  progress    Int       @default(0)
  maxProgress Int?
  result      String? // JSON
  error       String?
  tenantId    String?
  userId      String?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("jobs")
}

// ============================================================================
// AuditLog
// ============================================================================

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  projectId      String?
  userId         String?
  action         String
  entity         String
  entityId       String?
  changes        String? // JSON
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// ActionItem
// ============================================================================

model ActionItem {
  id                  String           @id @default(uuid())
  projectId           String
  title               String
  description         String?
  businessImpact      String?
  seoImpact           String?
  priority            ActionPriority   @default(MEDIUM)
  effort              ActionEffort     @default(MEDIUM)
  owner               String?
  deadline            DateTime?
  status              ActionItemStatus @default(PENDING)
  automationAvailable Boolean          @default(false)
  approvalRequired    Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("action_items")
}

// ============================================================================
// UserSettings
// ============================================================================

model UserSettings {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  locale                  String   @default("nl-NL")
  timezone                String?
  automationLevel         String?
  notificationPreferences String? // JSON
  privacyPreferences      String? // JSON
  theme                   String   @default("system")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_settings")
}
