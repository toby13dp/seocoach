// Phase 12: Enums — Migrations & Deployments
// ============================================================================

enum MigrationCheckStatus {
  NOG_TE_CONTROLEREN
  KLAAR
  PROBLEEM_GEVONDEN
  BLOKKEERT_LANCERING
  GOEDGEKEURD
}

enum MigrationProjectStatus {
  PLANNING
  CRAWLING_OLD
  CRAWLING_NEW
  MAPPING
  PRE_LAUNCH
  LIVE
  POST_LAUNCH
  COMPLETED
}

enum DeploymentProvider {
  GITHUB
  GITLAB
  GENERIC_CICD
}

enum DeploymentCheckType {
  ROBOTS_TXT
  CANONICALS
  TITLES
  META_ROBOTS
  SITEMAPS
  STATUS_CODES
  STRUCTURED_DATA
  INTERNAL_LINKS
  RENDERING
  PERFORMANCE
  CRITICAL_URLS
}

enum DeploymentCheckStatus {
  PASSING
  FAILING
  WARNING
  NOT_CHECKED
}

// ============================================================================
// Phase 12: Migration Models
// ============================================================================

model MigrationProject {
  id              String                @id @default(uuid())
  organizationId  String
  projectId       String
  // Details
  name            String                // Dutch name
  description     String?               // Dutch description
  // URLs
  oldSiteUrl      String
  newSiteUrl      String
  // Status
  status          MigrationProjectStatus @default(PLANNING)
  // Progress tracking
  oldUrlCount     Int                   @default(0)
  newUrlCount     Int                   @default(0)
  mappedCount     Int                   @default(0)
  redirectCount   Int                   @default(0)
  issueCount      Int                   @default(0)
  blockerCount    Int                   @default(0)
  // Dates
  plannedLaunchDate DateTime?
  actualLaunchDate  DateTime?
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  urlMappings     MigrationUrlMapping[]
  preLaunchChecks MigrationPreLaunchCheck[]
  launchBlockers  MigrationLaunchBlocker[]

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@map("migration_projects")
}

model MigrationUrlMapping {
  id                String              @id @default(uuid())
  migrationProjectId String
  // URLs
  oldUrl            String
  newUrl            String?
  // Redirect
  redirectType      Int                 @default(301) // 301, 302, 307, 308
  // Comparison checks
  metadataStatus    MigrationCheckStatus @default(NOG_TE_CONTROLEREN)
  headingsStatus    MigrationCheckStatus @default(NOG_TE_CONTROLEREN)
  contentStatus     MigrationCheckStatus @default(NOG_TE_CONTROLEREN)
  canonicalStatus   MigrationCheckStatus @default(NOG_TE_CONTROLEREN)
  robotsStatus      MigrationCheckStatus @default(NOG_TE_CONTROLEREN)
  structuredDataStatus MigrationCheckStatus @default(NOG_TE_CONTROLEREN)
  internalLinksStatus  MigrationCheckStatus @default(NOG_TE_CONTROLEREN)
  // Comparison details
  metadataDiff      String?             // JSON: { old: {}, new: {}, changes: [] }
  headingsDiff      String?             // JSON
  contentDiff       String?             // JSON: similarity score + differences
  canonicalDiff     String?             // JSON
  robotsDiff        String?             // JSON
  structuredDataDiff String?            // JSON
  internalLinksDiff String?             // JSON
  // Metadata
  notes             String?             // Dutch notes
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  migrationProject MigrationProject @relation(fields: [migrationProjectId], references: [id], onDelete: Cascade)

  @@index([migrationProjectId])
  @@index([oldUrl])
  @@index([newUrl])
  @@index([metadataStatus])
  @@index([deletedAt])
  @@map("migration_url_mappings")
}

model MigrationPreLaunchCheck {
  id                String              @id @default(uuid())
  migrationProjectId String
  // Check details
  category          String              // "redirects", "metadata", "content", etc.
  title             String              // Dutch title
  description       String?             // Dutch description
  status            MigrationCheckStatus @default(NOG_TE_CONTROLEREN)
  // Result
  details           String?             // JSON: check result details
  // Metadata
  checkedBy         String?             // userId
  checkedAt         DateTime?
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  migrationProject MigrationProject @relation(fields: [migrationProjectId], references: [id], onDelete: Cascade)

  @@index([migrationProjectId])
  @@index([category])
  @@index([status])
  @@index([deletedAt])
  @@map("migration_pre_launch_checks")
}

model MigrationLaunchBlocker {
  id                String    @id @default(uuid())
  migrationProjectId String
  // Blocker details
  title             String    // Dutch title
  description       String    // Dutch description
  severity          String    @default("high") // "medium", "high", "critical"
  entityType        String?   // "url_mapping", "redirect", "check"
  entityId          String?
  // Resolution
  isResolved        Boolean   @default(false)
  resolvedBy        String?   // userId
  resolvedAt        DateTime?
  resolutionNotes   String?   // Dutch resolution notes
  // Metadata
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  migrationProject MigrationProject @relation(fields: [migrationProjectId], references: [id], onDelete: Cascade)

  @@index([migrationProjectId])
  @@index([isResolved])
  @@index([severity])
  @@index([deletedAt])
  @@map("migration_launch_blockers")
}

// ============================================================================
// Phase 12: Deployment Monitoring Models
// ============================================================================

model DeploymentRecord {
  id              String    @id @default(uuid())
  organizationId  String
  projectId       String
  // Provider
  provider        DeploymentProvider
  // Deployment details
  commitSha       String?
  branch          String?
  environment     String?   // "production", "staging", etc.
  deployedAt      DateTime
  deployedBy      String?   // userId or external name
  // Before-and-after
  preDeploymentSnapshot String? // JSON: snapshot of key SEO metrics before
  postDeploymentSnapshot String? // JSON: snapshot after
  // Regression
  regressionFound Boolean   @default(false)
  regressionDetails String? // JSON: list of regression findings
  // Severity & action
  severity        String    @default("none") // "none", "low", "medium", "high", "critical"
  suggestedRollback Boolean @default(false)
  rollbackReason  String?   // Dutch reason
  // Blocking
  isBlocking      Boolean   @default(false) // Must be explicitly enabled
  blockingEnabled Boolean   @default(false)
  // Notification
  isNotified      Boolean   @default(false)
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checks       DeploymentCheck[]

  @@index([organizationId])
  @@index([projectId])
  @@index([provider])
  @@index([deployedAt])
  @@index([regressionFound])
  @@index([isBlocking])
  @@index([deletedAt])
  @@map("deployment_records")
}

model DeploymentCheck {
  id              String                @id @default(uuid())
  deploymentId    String
  // Check type
  checkType       DeploymentCheckType
  // Result
  status          DeploymentCheckStatus @default(NOT_CHECKED)
  beforeValue     String?               // JSON: value before deployment
  afterValue      String?               // JSON: value after deployment
  diff            String?               // JSON: differences found
  // Finding
  finding         String?               // Dutch description of finding
  severity        String                @default("none") // "none", "info", "warning", "error", "critical"
  // Metadata
  checkedAt       DateTime?
  deletedAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  deployment DeploymentRecord @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId])
  @@index([checkType])
  @@index([status])
  @@index([severity])
  @@index([deletedAt])
  @@map("deployment_checks")
}
