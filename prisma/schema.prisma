// Client model extended with agency fields (add columns to existing Client)
// We add these as a separate related model to avoid migration issues

model ClientExtension {
  id              String            @id @default(uuid())
  clientId        String            @unique
  // Contract & limits
  contractStart   DateTime?
  contractEnd     DateTime?
  contractType    String?           // "monthly", "quarterly", "yearly", "project"
  monthlyHours    Float?            // Contracted hours per month
  maxProjects     Int?              // Maximum projects allowed
  maxKeywords     Int?              // Maximum keywords tracked
  maxPages        Int?              // Maximum pages crawled
  // Financials (restricted permissions)
  monthlyFee      Float?            // Monthly fee in EUR
  currency        String            @default("EUR")
  costRate        Float?            // Internal cost rate
  profitability   Float?            // Computed: (fee - cost) / fee
  billingNotes    String?           // Internal billing notes (NOT client-visible)
  // Health
  healthStatus    ClientHealthStatus @default(GOOD)
  healthScore     Float             @default(50) // 0-100
  healthNotes     String?           // JSON: Dutch health notes (internal)
  // SLA
  slaResponseHours Int?             // Response SLA in hours
  slaDeliveryHours Int?             // Delivery SLA in hours
  slaStatus       SLAStatus         @default(ON_TRACK)
  // Metadata
  lastHealthCheck DateTime?
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([healthStatus])
  @@index([slaStatus])
  @@index([deletedAt])
  @@map("client_extensions")
}

