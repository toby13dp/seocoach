// ============================================================================
// Phase 11: Copilot Models
// ============================================================================

model CopilotConversation {
  id              String    @id @default(uuid())
  organizationId  String
  projectId       String
  userId          String
  // Conversation metadata
  title           String    // Dutch title
  // Context
  contextData     String?   // JSON: project context for retrieval
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages     CopilotMessage[]

  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
  @@index([deletedAt])
  @@map("copilot_conversations")
}

model CopilotMessage {
  id              String    @id @default(uuid())
  conversationId  String
  // Message content
  role            String    // "user", "assistant", "system"
  content         String    // Dutch content
  // Evidence & citations
  citations       String?   // JSON: [{ recordType, recordId, url, snippet }]
  // Tool usage
  toolsUsed       String?   // JSON: [{ tool, input, output }]
  // Safety
  hasWarning      Boolean   @default(false)
  warningType     String?   // "missing_data", "uncertainty", "no_access"
  // Metadata
  tokenCount      Int?
  modelUsed       String?
  createdAt       DateTime  @default(now())

  conversation CopilotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
  @@map("copilot_messages")
}

// ============================================================================
// Phase 11: Agent Framework Models
// ============================================================================

model AgentRun {
  id              String          @id @default(uuid())
  organizationId  String
  projectId       String
  // Agent identification
  agentType       AgentType
  // Objective
  objective       String          // Dutch objective
  // Model configuration
  model           String          // "gpt-4", "claude-3", etc.
  // Inputs & outputs
  inputs          String          // JSON: agent inputs
  retrievedSources String?        // JSON: sources used for grounding
  proposedActions  String?        // JSON: proposed but not yet executed
  completedActions String?        // JSON: actions that were executed
  // Approvals
  approvals       String?         // JSON: approval records [{ action, approvedBy, approvedAt }]
  // Execution
  status          AgentRunStatus  @default(PENDING)
  maxSteps        Int             @default(10)
  currentStep     Int             @default(0)
  timeoutMs       Int             @default(300000) // 5 minutes
  // Results
  result          String?         // JSON: final result
  errors          String?         // JSON: error records
  confidence      Float?          // 0-1
  // Cost tracking
  inputTokens     Int             @default(0)
  outputTokens    Int             @default(0)
  costEur         Float           @default(0)
  // Duration
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  // Metadata
  cancellationRequested Boolean    @default(false)
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([agentType])
  @@index([status])
  @@index([startedAt])
  @@index([deletedAt])
  @@map("agent_runs")
}

// ============================================================================
// Phase 11: Automation Rules
// ============================================================================

model AutomationRule {
  id              String                @id @default(uuid())
  organizationId  String
  projectId       String?
  // Rule definition
  name            String                // Dutch name
  description     String?               // Dutch description
  // Trigger
  triggerType     AutomationTriggerType
  triggerConfig   String?               // JSON: trigger-specific config
  // Conditions (AND-combined)
  conditions      String?               // JSON: [{ field, operator, value }]
  // Actions
  actions         String                // JSON: [{ type: AutomationActionType, config: {} }]
  // Safety
  requiresApproval Boolean              @default(false)
  approvalConfig  String?               // JSON: { approvers: [], riskThreshold: string }
  isHighRisk      Boolean               @default(false)
  // Status
  status          AutomationRuleStatus  @default(DRAFT)
  // Execution tracking
  lastTriggeredAt DateTime?
  triggerCount    Int                   @default(0)
  // Metadata
  createdBy       String?               // userId
  deletedAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([triggerType])
  @@index([status])
  @@index([isHighRisk])
  @@index([deletedAt])
  executions AutomationExecution[]
  @@map("automation_rules")
}

model AutomationExecution {
  id              String    @id @default(uuid())
  ruleId          String
  organizationId  String
  // Trigger data
  triggerType     AutomationTriggerType
  triggerData     String?   // JSON: data that triggered the rule
  // Actions executed
  actionsExecuted String?   // JSON: [{ type, result, error }]
  // Result
  status          String    @default("running") // "running", "completed", "failed", "awaiting_approval"
  error           String?   // Error message (Dutch)
  // Duration
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  durationMs      Int?
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([organizationId])
  @@index([status])
  @@index([startedAt])
  @@index([deletedAt])
  @@map("automation_executions")
}

