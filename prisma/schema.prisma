  // Item details
  itemType        String              // "content", "technical_action", "report", "redirect", etc.
  itemId          String?             // ID of the item requiring approval
  title           String              // Dutch title
  description     String?             // Dutch description
  evidence        String?             // JSON: supporting evidence
  // Submitter
  submittedBy     String?             // userId
  submittedAt     DateTime?
  // Reviewer
  reviewedBy      String?             // userId
  reviewedAt      DateTime?
  reviewNotes     String?             // Dutch review notes
  // Status
  status          ApprovalQueueStatus @default(PENDING)
  // Risk level
  riskLevel       String              @default("low") // "low", "medium", "high", "critical"
  // Client visibility
  isClientVisible Boolean             @default(false)
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@index([itemType])
  @@index([submittedBy])
  @@index([deletedAt])
  @@map("approval_queue_items")
}

// ============================================================================
// Phase 10: Internal Notes
