// ============================================================================
// Phase 5: Alerts
// ============================================================================

model Alert {
  id               String        @id @default(uuid())
  projectId        String
  type             AlertType
  severity         AlertSeverity @default(MEDIUM)
  status           AlertStatus   @default(ACTIVE)
  // Alert content
  title            String        // Dutch title
  message          String        // Dutch explanation
  evidence         String?       // JSON evidence data
  metricValue      Float?
  previousValue    Float?
  changePercentage Float?
  threshold        Float?
  // Minimum data volume check
  dataPointsUsed   Int           @default(0)
  dataSufficient   Boolean       @default(true)
  dataNote         String?       // Dutch explanation if data insufficient
  // Grouping and deduplication
  alertGroup       String?       // group key for related alerts
  // Lifecycle
  acknowledgedBy   String?
  acknowledgedAt   DateTime?
  snoozedUntil     DateTime?
  snoozedBy        String?
  resolvedBy       String?
  resolvedAt       DateTime?
  dismissedBy      String?
  dismissedAt      DateTime?
  assignedTo       String?
  resolution       String?       // Dutch resolution note
  // Notification
  notifiedChannels String?       // JSON array: email, in_app, webhook
  // Anomaly detection metadata
  anomalyScore     Float?
  anomalyMethod    String?       // statistical, threshold, trend
  // Metadata
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([alertGroup])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("alerts")
}

// ============================================================================
