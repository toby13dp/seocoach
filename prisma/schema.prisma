  titleQuality    Float?        @default(0) // 0-100
  descriptionQuality Float?     @default(0)
  structuredDataScore Float?    @default(0)
  imageScore      Float?        @default(0)
  overallSeoScore Float?        @default(0)
  seoIssues       String?       // JSON array of Dutch SEO issues
  // Revenue tracking
  revenue30d      Float?        @default(0)
  revenue90d      Float?        @default(0)
  unitsSold30d    Int?
  unitsSold90d    Int?
  // Internal links
  internalLinkCount Int?        @default(0)
  // Seasonal data
  isSeasonal      Boolean       @default(false)
  seasonalMonths  String?       // JSON array of active months [1-12]
  // Source
  source          String?       // "woocommerce", "csv_import", "manual"
  externalId      String?
  importBatch     String?
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  category        ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parentProduct   Product?         @relation("ProductVariations", fields: [parentProductId], references: [id], onDelete: Cascade)
  variations      Product[]        @relation("ProductVariations")
  feedItems       ProductFeedItem[]

  @@index([projectId])
  @@index([sku])
  @@index([gtin])
  @@index([categoryId])
  @@index([stockStatus])
  @@index([overallSeoScore])
  @@index([revenue30d])
  @@index([parentProductId])
  @@index([isSeasonal])
  @@index([source])
  @@index([importBatch])
  @@index([deletedAt])
  @@map("products")
}

model ProductCategory {
  id              String   @id @default(uuid())
  projectId       String
  name            String
  slug            String?
  description     String?
  parentId        String?
  // Quality analysis
  productCount    Int      @default(0)
  qualityScore    Float?   @default(0) // 0-100
  seoIssues       String?  // JSON array of Dutch issues
  hasDescription  Boolean  @default(false)
  hasStructuredData Boolean @default(false)
  // Source
  externalId      String?
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent          ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        ProductCategory[] @relation("CategoryHierarchy")
  products        Product[]

  @@index([projectId])
  @@index([parentId])
  @@index([qualityScore])
  @@index([deletedAt])
  @@map("product_categories")
}

model FacetedNavigationIssue {
  id              String   @id @default(uuid())
  projectId       String
  // The faceted URL that has issues
  url             String
  // What kind of issue
  issueType       String   // "duplicate_content", "thin_content", "crawled_facet", "noindex_needed"
  severity        String   // "error", "warning", "info"
  // Dutch description and recommendation
  description     String   // Dutch description of the issue
  recommendation  String   // Dutch recommendation
  // Evidence
  parameterName   String?  // e.g. "color", "size", "page"
  parameterValue  String?  // e.g. "red", "xl", "2"
  canonicalUrl    String?  // Recommended canonical
  // Status
  isResolved      Boolean  @default(false)
  resolvedAt      DateTime?
  // Metadata
  detectedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([issueType])
  @@index([severity])
  @@index([isResolved])
  @@index([detectedAt])
  @@map("faceted_navigation_issues")
}

