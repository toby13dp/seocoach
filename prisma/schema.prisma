model LocationHealthCheck {
  id           String             @id @default(uuid())
  projectId    String
  locationId   String
  category     LocalHealthCategory
  status       LocalHealthStatus  @default(NOT_CHECKED)
  score        Float              @default(0) // 0-100
  // Dutch findings
  title        String             // Dutch title
  description  String             // Dutch description
  recommendation String?          // Dutch recommendation
  evidence     String?            // JSON evidence
  // Metadata
  checkedAt    DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([locationId])
  @@index([category])
  @@index([status])
  @@index([score])
  @@map("location_health_checks")
}

model GoogleBusinessProfile {
  id              String   @id @default(uuid())
  projectId       String
  locationId      String   @unique
  // GBP connection
  accountId       String?
  locationIdGBP   String?
  accessToken     String?  // encrypted
  refreshToken    String?  // encrypted
  // Profile data
  businessName    String?
  primaryCategory String?
  categories      String?  // JSON array
  websiteUrl      String?
  // Review stats from GBP
  avgRating       Float?
  totalReviews    Int      @default(0)
  lastSyncAt      DateTime?
  syncStatus      String   @default("not_connected") // not_connected, connected, syncing, error
  syncError       String?  // Dutch error description
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([syncStatus])
  @@map("google_business_profiles")
}

model RankImport {
  id          String   @id @default(uuid())
  projectId   String
  locationId  String?
  importBatch String   @unique
  source      String   // "csv_import", "gbp_adapter", "manual"
  rowCount    Int      @default(0)
  successCount Int     @default(0)
  errorCount  Int      @default(0)
  errors      String?  // JSON array of error messages
  importedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([locationId])
  @@index([importBatch])
  @@index([source])
  @@map("rank_imports")
}

// ============================================================================
// Phase 7: Reviews & Reputation Models
// ============================================================================

model Review {
  id            String         @id @default(uuid())
  projectId     String
  locationId    String?
  // Source
  source        ReviewSource
  externalId    String?        // ID from external platform
  sourceUrl     String?        // Link to original review
  // Reviewer
  authorName    String?
  authorAvatar  String?
  isVerified    Boolean        @default(false)
  // Content
  rating        Float          @default(0) // 1-5
  title         String?
  content       String?
  // Analysis
  sentiment     ReviewSentiment @default(NEUTRAL)
  sentimentScore Float?        // -1 to 1
  themes        String?        // JSON array of detected themes
  complaints    String?        // JSON array of Dutch complaints
  compliments   String?        // JSON array of Dutch compliments
  productIssues String?        // JSON array of Dutch product issues
  serviceIssues String?        // JSON array of Dutch service issues
  faqOpportunities String?     // JSON array of Dutch FAQ opportunities
  contentOpportunities String? // JSON array of Dutch content opportunities
  trustSignals  String?        // JSON array of Dutch trust signals
  // Metadata
  language      String?        @default("nl")
  reviewDate    DateTime?
  responseDraftId String?      @unique // FK to ReviewResponse
  importBatch   String?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  location        Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  responseDraft   ReviewResponse?     @relation("ReviewResponseDraft", fields: [responseDraftId], references: [id], onDelete: SetNull)
  responses       ReviewResponse[]    @relation("ReviewResponses")

  @@index([projectId])
  @@index([locationId])
  @@index([source])
  @@index([rating])
  @@index([sentiment])
  @@index([reviewDate])
  @@index([externalId])
  @@index([importBatch])
  @@index([deletedAt])
  @@map("reviews")
}

model ReviewResponse {
  id          String             @id @default(uuid())
  projectId   String
  reviewId    String
  // Response content
  content     String             // Dutch response text
  // Approval workflow
  status      ReviewResponseStatus @default(DRAFT)
  submittedBy String?
  reviewedBy  String?
  reviewedAt  DateTime?
  rejectionReason String?        // Dutch reason for rejection
  // Publishing
  publishedAt DateTime?
  publishError String?           // Dutch error description
  // Metadata
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  review      Review  @relation("ReviewResponses", fields: [reviewId], references: [id], onDelete: Cascade)
  draftForReview Review? @relation("ReviewResponseDraft")

  @@index([projectId])
  @@index([reviewId])
  @@index([status])
  @@index([submittedBy])
  @@map("review_responses")
}
