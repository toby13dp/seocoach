model LocalCompetitor {
  id          String   @id @default(uuid())
  projectId   String
  locationId  String
  name        String
  address     String?
  city        String?
  postalCode  String?
  website     String?
  avgRating   Float?
  reviewCount Int      @default(0)
  distance    Float?   // km from our location
  strengths   String?  // JSON array of Dutch strengths
  weaknesses  String?  // JSON array of Dutch weaknesses
  notes       String?  // Dutch notes
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

