// ============================================================================
// Phase 5: Daily Metrics (time-series data from GSC/GA4/CSV)
// ============================================================================

model DailyMetric {
  id               String   @id @default(uuid())
  projectId        String
  connectionId     String
  date             DateTime
  // Search metrics
  clicks           Int      @default(0)
  impressions      Int      @default(0)
  ctr              Float    @default(0)
  averagePosition  Float    @default(0)
  // Analytics metrics
  sessions         Int      @default(0)
  users            Int      @default(0)
  newUsers         Int      @default(0)
  pageViews        Int      @default(0)
  bounceRate       Float?
  avgSessionDuration Float?  // seconds
  // Conversion metrics
  conversions      Int      @default(0)
  conversionRate   Float?
  // Revenue metrics
  revenue          Float?
  productRevenue   Float?
  // Segmentation
  source           String?  // organic, paid, social, direct, referral, etc.
  medium           String?
  campaign         String?
  device           String?  // desktop, mobile, tablet
  country          String?
  landingPage      String?  // URL
  // Metadata
  importBatch      String?  // batch ID for bulk imports
  createdAt        DateTime @default(now())

  @@unique([projectId, connectionId, date, source, medium, device, country, landingPage])
  @@index([projectId])
  @@index([connectionId])
  @@index([date])
  @@index([source])
  @@index([device])
  @@index([country])
  @@index([landingPage])
  @@index([importBatch])
  @@map("daily_metrics")
}

// ============================================================================
