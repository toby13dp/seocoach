  snapshotGeneratedAt DateTime?
  // Output
  htmlOutput        String?        // generated HTML
  pdfPath           String?        // path to generated PDF
  // Approval
  approvedBy        String?
  approvedAt        DateTime?
  // Sharing
  shareToken        String?        @unique
  sharePassword     String?        // hashed password for shared reports
  shareExpiresAt    DateTime?
  shareAccessCount  Int            @default(0)
  // Scheduling
  scheduledAt       DateTime?
  // Version tracking
  version           Int            @default(1)
  parentReportId    String?        // for version history
  // Metadata
  createdById       String?
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([status])
  @@index([whiteLabelId])
  @@index([shareToken])
  @@index([scheduledAt])
  @@index([deletedAt])
  @@map("reports")
}

