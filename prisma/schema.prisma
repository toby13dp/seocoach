  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider AIProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  callLogs AICallLog[]

  @@unique([providerId, name, version])
  @@index([providerId])
  @@index([category])
  @@index([isActive])
  @@map("prompt_templates")
}

