  @@index([organizationId])
  @@index([projectId])
  @@index([provider])
  @@index([status])
  @@index([deletedAt])
  @@map("pm_integrations")
}

model PMTaskExport {
  id              String    @id @default(uuid())
  integrationId   String
  // SEO Task reference
  taskId          String?   // Internal action item ID
  taskType        String    // "action_item", "technical_issue", "content_brief", etc.
  // Exported task details
  externalId      String?   // ID in external system
  externalUrl     String?   // Link to task in external system
  // Task content
  plainSummary    String    // Dutch plain-language summary
  technicalDetail String?   // Dutch technical detail
  priority        String    // "low", "medium", "high", "critical"
  evidence        String?   // JSON: supporting evidence
  urls            String?   // JSON: array of relevant URLs
  deadline        DateTime?
  owner           String?   // Assigned user
  sourceLink      String?   // Link back to SEOCoach
  // Status
  exportStatus    String    @default("pending") // "pending", "exported", "synced", "error"
  lastSyncAt      DateTime?
  syncError       String?   // Error message
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  integration PMIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([taskId])
  @@index([exportStatus])
  @@index([externalId])
  @@index([deletedAt])
  @@map("pm_task_exports")
}

// ============================================================================
// Phase 10: Benchmarking
// ============================================================================

model BenchmarkResult {
  id              String            @id @default(uuid())
  organizationId  String
  projectId       String
  // Category
  category        BenchmarkCategory
  // Score
  score           Float             // 0-100
  previousScore   Float?            // Previous period score
  // Period
  periodStart     DateTime
  periodEnd       DateTime
  // Details
  details         String?           // JSON: detailed breakdown
  // Cross-client comparison (requires explicit permission)
  percentile      Float?            // Position among anonymised peers
  peerCount       Int?              // Number of anonymised peers (minimum 5 for privacy)
  isAnonymised    Boolean           @default(false)
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, category, periodStart])
  @@index([organizationId])
  @@index([projectId])
  @@index([category])
  @@index([periodStart, periodEnd])
  @@index([deletedAt])
  @@map("benchmark_results")
}

model BenchmarkConsent {
  id              String    @id @default(uuid())
  organizationId  String
  projectId       String
  // Consent for cross-client aggregated benchmarking
  category        BenchmarkCategory
  isConsented     Boolean   @default(false)
  consentedBy     String?   // userId
  consentedAt     DateTime?
  // Metadata
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, category])
  @@index([organizationId])
  @@index([projectId])
  @@index([isConsented])
  @@index([deletedAt])
  @@map("benchmark_consents")
}

