  targetRank  Int?
  url         String?
  isActive    Boolean            @default(true)
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([locationId])
  @@index([keyword])
  @@index([intent])
  @@index([currentRank])
  @@index([deletedAt])
  @@map("local_keywords")
}

model LocalLandingPage {
