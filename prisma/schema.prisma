model DataConnection {
  id               String              @id @default(uuid())
  projectId        String
  name             String
  type             DataConnectionType
  status           DataConnectionStatus @default(PENDING)
  // Connection config (JSON): OAuth tokens, API keys, file references, etc.
  config           String?
  // Last sync tracking
  lastSyncAt       DateTime?
  lastSyncStatus   String?             // success, partial, failed
  lastSyncError    String?
  nextSyncAt       DateTime?
  syncIntervalMinutes Int              @default(1440) // 24h default
  // Data freshness
  dataStartDate    DateTime?
  dataEndDate      DateTime?
  dataNote         String?             // Dutch explanation for missing data
  // Metadata
  metadata         String?             // JSON: account info, property info, etc.
  deletedAt        DateTime?
  createdAt        DateTime            @default(now())
