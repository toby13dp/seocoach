  projectId   String
  locationId  String
  url         String
  title       String?
  metaDescription String?
  h1          String?
  wordCount   Int      @default(0)
  hasStructuredData Boolean @default(false)
  hasNAP      Boolean  @default(false)
  hasMap      Boolean  @default(false)
  hasOpeningHours Boolean @default(false)
  qualityScore Float  @default(0) // 0-100
  issues      String?  // JSON array of Dutch issues
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

