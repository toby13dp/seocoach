// ============================================================================
// Prisma Schema — AI-Driven SEO Automation Platform (Phase 1-12)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum Role {
  PLATFORM_ADMIN
  ORG_OWNER
  AGENCY_OWNER
  SEO_MANAGER
  CONTENT_MANAGER
  EDITOR
  DEVELOPER
  CLIENT
  READ_ONLY
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionEffort {
  MINIMAL
  LOW
  MEDIUM
  HIGH
}

enum ActionItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum PermissionCategory {
  MANAGE_USERS
  MANAGE_PROJECTS
  MANAGE_CONTENT
  MANAGE_SETTINGS
  VIEW_ANALYTICS
  MANAGE_INTEGRATIONS
  MANAGE_PUBLISHING
  VIEW_REPORTS
}

enum CrawlStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}

enum PageStatus {
  OK
  REDIRECT
  CLIENT_ERROR
  SERVER_ERROR
  BLOCKED
  TIMEOUT
}

enum Indexability {
  INDEXABLE
  NOINDEX
  BLOCKED_ROBOTS
  CANONICALIZED
  BLOCKED_META
  UNKNOWN
}

enum ContentType {
  HTML
  PDF
  IMAGE
  VIDEO
  OTHER
}

enum IssueSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum SearchIntent {
  INFORMATIONAL
  NAVIGATIONAL
  TRANSACTIONAL
  COMMERCIAL_INVESTIGATION
  LOCAL
  BRANDED
  UNKNOWN
}

enum FunnelStage {
  AWARENESS
  CONSIDERATION
  DECISION
  RETENTION
  UNKNOWN
}

enum PruningAction {
  KEEP
  IMPROVE
  MERGE
  REDIRECT
  NOINDEX
  REMOVE
}

enum ContentApprovalStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum AIProviderType {
  OLLAMA
  OPENAI_COMPATIBLE
  CUSTOM
}

// ============================================================================
// NextAuth.js v4 Models
// ============================================================================

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// User
// ============================================================================

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  name                    String?
  hashedPassword          String?
  emailVerified           DateTime?
  image                   String?
  locale                  String    @default("nl-NL")
  timezone                String?
  automationLevel         String?
  notificationPreferences String?
  privacyPreferences      String?
  deletedAt               DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships OrganizationMembership[]
  invitations Invitation[]             @relation("InvitedBy")
  settings    UserSettings?
  auditLogs   AuditLog[]
  jobs        Job[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

// ============================================================================
// Organization
// ============================================================================

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  website     String?
  logoUrl     String?
  locale      String    @default("nl-NL")
  settings    String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships OrganizationMembership[]
  invitations Invitation[]
  clients     Client[]
  projects    Project[]
  auditLogs   AuditLog[]
  // Phase 10 relations
  deliverables      Deliverable[]
  timeEntries       TimeEntry[]
  recurringTasks    RecurringTask[]
  approvalItems     ApprovalQueueItem[]
  internalNotes     InternalNote[]
  pmIntegrations    PMIntegration[]
  benchmarkResults  BenchmarkResult[]
  benchmarkConsents BenchmarkConsent[]
  agencyAlerts      AgencyAlert[]
  monthlyWorkSummaries MonthlyWorkSummary[]
  // Phase 11 relations
  copilotConversations CopilotConversation[]
  agentRuns          AgentRun[]
  automationRules    AutomationRule[]
  // Phase 12 relations
  migrationProjects  MigrationProject[]
  deploymentRecords  DeploymentRecord[]

  @@index([slug])
  @@index([deletedAt])
  @@map("organizations")
}

// ============================================================================
// OrganizationMembership
// ============================================================================

model OrganizationMembership {
  id             String    @id @default(uuid())
  userId         String
  organizationId String
  role           Role      @default(READ_ONLY)
  invitedAt      DateTime?
  acceptedAt     DateTime?
  deletedAt      DateTime?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([role])
  @@index([deletedAt])
  @@map("organization_memberships")
}

// ============================================================================
// Invitation
// ============================================================================

model Invitation {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           Role      @default(READ_ONLY)
  token          String    @unique
  invitedBy      String
  expiresAt      DateTime
  acceptedAt     DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
  @@index([token])
  @@map("invitations")
}

// ============================================================================
// Client
// ============================================================================

model Client {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  slug           String
  description    String?
  website        String?
  industry       String?
  notes          String?
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]
  // Phase 10 relations
  extension          ClientExtension?
  portalAccess       ClientPortalAccess[]
  notificationPrefs  ClientNotificationPreference?
  deliverables       Deliverable[]
  timeEntries        TimeEntry[]
  monthlyWorkSummaries MonthlyWorkSummary[]
  recurringTasks     RecurringTask[]
  approvalItems      ApprovalQueueItem[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("clients")
}

// ============================================================================
// Project
// ============================================================================

model Project {
  id                  String        @id @default(uuid())
  organizationId      String
  clientId            String?
  name                String
  slug                String
  description         String?
  websiteUrl          String?
  status              ProjectStatus @default(ACTIVE)
  settings            String?
  onboardingCompleted Boolean       @default(false)
  onboardingStep      Int           @default(0)
  deletedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now()) @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  domains      Domain[]
  locations    Location[]
  brandProfile BrandProfile?
  jobs         Job[]
  auditLogs    AuditLog[]
  actionItems  ActionItem[]
  crawlSessions CrawlSession[]
  pages         Page[]
  keywords      Keyword[]
  topics        Topic[]
  aiProviders   AIProvider[]
  contentBriefs ContentBrief[]
  // Phase 10 relations
  deliverables      Deliverable[]
  timeEntries       TimeEntry[]
  recurringTasks    RecurringTask[]
  approvalItems     ApprovalQueueItem[]
  pmIntegrations    PMIntegration[]
  benchmarkResults  BenchmarkResult[]
  benchmarkConsents BenchmarkConsent[]
  // Phase 11 relations
  copilotConversations CopilotConversation[]
  agentRuns          AgentRun[]
  automationRules    AutomationRule[]
  // Phase 12 relations
  migrationProjects  MigrationProject[]
  deploymentRecords  DeploymentRecord[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([deletedAt])
  @@map("projects")
}

// ============================================================================
// Domain
// ============================================================================

model Domain {
  id                 String    @id @default(uuid())
  projectId          String
  domain             String
  isPrimary          Boolean   @default(false)
  verifiedAt         DateTime?
  verificationMethod String?
  deletedAt          DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, domain])
  @@index([projectId])
  @@index([deletedAt])
  @@map("domains")
}

// ============================================================================
// Location
// ============================================================================

model Location {
  id         String    @id @default(uuid())
  projectId  String
  name       String
  // NAP (Name, Address, Phone)
  address    String?
  city       String?
  postalCode String?
  country    String?   @default("NL")
  phone      String?
  email      String?
  website    String?
  // Geo
  latitude   Float?
  longitude  Float?
  // Opening hours (JSON: {"mon":{"open":"09:00","close":"18:00"},...})
  openingHours  String?  // JSON object
  // Google Business Profile
  gbpAccountId String?
  gbpLocationId String?
  gbpStatus    String?  @default("not_connected") // not_connected, connected, error
  // Local SEO metadata
  businessType  String?  // e.g. "restaurant", "dentist"
  serviceArea   String?  // JSON array of served areas
  localKeywordIds String?  // JSON array of local keyword IDs
  // Health & scoring
  napConsistency Float?  @default(0) // 0-100 NAP consistency score
  localHealthScore Float? @default(0) // 0-100 overall local health
  // Review aggregate
  avgRating    Float?   @default(0)
  reviewCount  Int      @default(0)
  // Structured data
  localStructuredData String? // JSON-LD for LocalBusiness
  // Metadata
  notes       String?  // Dutch notes
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  localKeywords    LocalKeyword[]
  landingPages     LocalLandingPage[]
  localCompetitors LocalCompetitor[]
  healthChecks     LocationHealthCheck[]
  reviews          Review[]
  googleBusinessProfile GoogleBusinessProfile?

  @@index([projectId])
  @@index([deletedAt])
  @@index([city])
  @@index([napConsistency])
  @@index([localHealthScore])
  @@index([avgRating])
  @@map("locations")
}

// ============================================================================
// BrandProfile
// ============================================================================

model BrandProfile {
  id                    String    @id @default(uuid())
  projectId             String
  brandName             String?
  description           String?
  products              String? // JSON
  services              String? // JSON
  audiences             String? // JSON
  regions               String? // JSON
  toneOfVoice           String?
  addressPreference     String?
  preferredTerminology  String? // JSON
  prohibitedTerminology String? // JSON
  allowedClaims         String? // JSON
  prohibitedClaims      String? // JSON
  proofPoints           String? // JSON
  certifications        String? // JSON
  contactInformation    String? // JSON
  conversionGoals       String? // JSON
  editorialRules        String? // JSON
  disclaimers           String? // JSON
  locale                String    @default("nl-NL")
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId])
  @@index([projectId])
  @@index([deletedAt])
  @@map("brand_profiles")
}

// ============================================================================
// Permission
// ============================================================================

model Permission {
  id          String             @id @default(uuid())
  name        String             @unique
  description String?
  category    PermissionCategory

  rolePermissions RolePermission[]

  @@index([category])
  @@map("permissions")
}

// ============================================================================
// RolePermission
// ============================================================================

model RolePermission {
  id           String @id @default(uuid())
  role         Role
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
  @@map("role_permissions")
}

// ============================================================================
// Job
// ============================================================================

model Job {
  id          String    @id @default(uuid())
  projectId   String
  type        String
  status      JobStatus @default(PENDING)
  progress    Int       @default(0)
  maxProgress Int?
  result      String? // JSON
  error       String?
  tenantId    String?
  userId      String?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("jobs")
}

// ============================================================================
// AuditLog
// ============================================================================

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  projectId      String?
  userId         String?
  action         String
  entity         String
  entityId       String?
  changes        String? // JSON
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// ActionItem
// ============================================================================

model ActionItem {
  id                  String           @id @default(uuid())
  projectId           String
  title               String
  description         String?
  businessImpact      String?
  seoImpact           String?
  priority            ActionPriority   @default(MEDIUM)
  effort              ActionEffort     @default(MEDIUM)
  owner               String?
  deadline            DateTime?
  status              ActionItemStatus @default(PENDING)
  automationAvailable Boolean          @default(false)
  approvalRequired    Boolean          @default(false)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("action_items")
}

// ============================================================================
// UserSettings
// ============================================================================

model UserSettings {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  locale                  String   @default("nl-NL")
  timezone                String?
  automationLevel         String?
  notificationPreferences String? // JSON
  privacyPreferences      String? // JSON
  theme                   String   @default("system")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_settings")
}

// ============================================================================
// Phase 2: Crawling & Technical SEO
// ============================================================================

model CrawlSession {
  id                String      @id @default(uuid())
  projectId         String
  status            CrawlStatus @default(PENDING)
  startUrl          String
  maxPages          Int         @default(500)
  maxDepth          Int         @default(10)
  crawlDelayMs      Int         @default(1000)
  respectRobotsTxt  Boolean     @default(true)
  followRedirects   Boolean     @default(true)
  includeSubdomains Boolean     @default(false)
  useRendering      Boolean     @default(false)
  pagesCrawled      Int         @default(0)
  pagesFound        Int         @default(0)
  issuesFound       Int         @default(0)
  errorCount        Int         @default(0)
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pages   Page[]
  issues  TechnicalIssue[]

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("crawl_sessions")
}

model Page {
  id                String       @id @default(uuid())
  crawlSessionId    String
  projectId         String
  url               String
  normalizedUrl     String
  statusCode        Int?
  status            PageStatus   @default(OK)
  contentType       ContentType  @default(HTML)
  title             String?
  description       String?
  h1                String?
  wordCount         Int          @default(0)
  canonicalUrl      String?
  indexability       Indexability @default(INDEXABLE)
  language          String?
  publicationDate   DateTime?
  modificationDate  DateTime?
  internalLinkCount Int          @default(0)
  externalLinkCount Int          @default(0)
  imageCount        Int          @default(0)
  imagesWithoutAlt  Int          @default(0)
  structuredData    String? // JSON
  crawlDepth        Int          @default(0)
  isOrphan          Boolean      @default(false)
  redirectChain     String? // JSON array of URLs
  finalUrl          String?
  loadTimeMs        Int?
  htmlSizeBytes     Int?
  contentHash       String?
  mainContent       String?
  internalLinks     String? // JSON array
  externalLinks     String? // JSON array
  images            String? // JSON array
  duplicateGroup    String?
  similarityScore   Float?
  conversionElements String? // JSON
  metaRobots        String?
  renderDiffDetected Boolean    @default(false)
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  crawlSession   CrawlSession      @relation(fields: [crawlSessionId], references: [id], onDelete: Cascade)
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots      PageSnapshot[]
  issues         TechnicalIssue[]
  renderedComparison RenderedComparison?
  keywordPages   KeywordPage[]

  @@unique([crawlSessionId, normalizedUrl])
  @@index([projectId])
  @@index([crawlSessionId])
  @@index([statusCode])
  @@index([indexability])
  @@index([contentType])
  @@index([crawlDepth])
  @@index([duplicateGroup])
  @@index([contentHash])
  @@index([deletedAt])
  @@map("pages")
}

model PageSnapshot {
  id         String   @id @default(uuid())
  pageId     String
  html       String
  source     String   @default("crawl") // crawl, render
  sizeBytes  Int?
  createdAt  DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([source])
  @@map("page_snapshots")
}

model TechnicalIssue {
  id                String         @id @default(uuid())
  projectId         String
  pageId            String?
  crawlSessionId    String
  ruleId            String
  ruleName          String
  dutchExplanation  String
  technicalDetails  String?
  evidence          String? // JSON
  severity          IssueSeverity  @default(WARNING)
  priority          ActionPriority @default(MEDIUM)
  impact            String?
  effort            ActionEffort   @default(MEDIUM)
  affectedUrls      String? // JSON array
  recommendedAction String?
  autoFixAvailable  Boolean        @default(false)
  confidence        Float          @default(1.0)
  dismissed         Boolean        @default(false)
  dismissedBy       String?
  dismissedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  page          Page?         @relation(fields: [pageId], references: [id], onDelete: SetNull)
  crawlSession  CrawlSession  @relation(fields: [crawlSessionId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([crawlSessionId])
  @@index([ruleId])
  @@index([severity])
  @@index([priority])
  @@index([dismissed])
  @@index([createdAt])
  @@map("technical_issues")
}

model RenderedComparison {
  id                 String   @id @default(uuid())
  pageId             String   @unique
  textDiff           String? // JSON diff
  linkDiff           String? // JSON diff
  canonicalDiff      String? // JSON diff
  robotsDiff         String? // JSON diff
  structuredDataDiff String? // JSON diff
  headingDiff        String? // JSON diff
  navigationDiff     String? // JSON diff
  hasSignificantDiff Boolean  @default(false)
  summary            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([hasSignificantDiff])
  @@map("rendered_comparisons")
}

// ============================================================================
// Phase 3: Keywords & Content Intelligence
// ============================================================================

model Keyword {
  id              String       @id @default(uuid())
  projectId       String
  keyword         String
  searchIntent    SearchIntent @default(UNKNOWN)
  funnelStage     FunnelStage  @default(UNKNOWN)
  searchVolume    Int?
  difficulty      Float?
  cpc             Float?
  currentRanking  Int?
  currentUrl      String?
  groupId         String?
  personaMapping  String?
  productMapping  String?
  serviceMapping  String?
  locationMapping String?
  seasonality     String? // JSON
  tags            String? // JSON array
  notes           String?
  source          String       @default("manual") // manual, csv, ai
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  opportunity  OpportunityScore?
  keywordPages KeywordPage[]
  topicKeywords TopicKeyword[]
  contentBriefs ContentBrief[]

  @@index([projectId])
  @@index([searchIntent])
  @@index([funnelStage])
  @@index([groupId])
  @@index([keyword])
  @@index([deletedAt])
  @@map("keywords")
}

model KeywordPage {
  id        String  @id @default(uuid())
  keywordId String
  pageId    String
  relevance Float   @default(0)

  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  page    Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([keywordId, pageId])
  @@index([keywordId])
  @@index([pageId])
  @@map("keyword_pages")
}

model OpportunityScore {
  id                  String   @id @default(uuid())
  keywordId           String   @unique
  totalScore          Float    @default(0)
  volumeScore         Float    @default(0)
  difficultyScore     Float    @default(0)
  relevanceScore      Float    @default(0)
  currentRankScore    Float    @default(0)
  intentScore         Float    @default(0)
  funnelScore         Float    @default(0)
  competitionScore    Float    @default(0)
  calculationDetails  String? // JSON - full calculation trace
  weightsVersion      String   @default("1.0")
  calculatedAt        DateTime @default(now())

  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@index([totalScore])
  @@map("opportunity_scores")
}

model Topic {
  id             String    @id @default(uuid())
  projectId      String
  name           String
  description    String?
  clusterId      String?
  isPillar       Boolean   @default(false)
  pillarPageId   String?
  suggestedUrl   String?
  searchIntent   SearchIntent @default(UNKNOWN)
  funnelStage    FunnelStage  @default(UNKNOWN)
  conversionGoal String?
  priority       ActionPriority @default(MEDIUM)
  impact         String?
  effort         ActionEffort   @default(MEDIUM)
  sortOrder      Int       @default(0)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cluster      TopicCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  topicKeywords TopicKeyword[]
  outgoingRelations TopicRelation[] @relation("FromTopic")
  incomingRelations TopicRelation[] @relation("ToTopic")
  contentBriefs ContentBrief[]

  @@index([projectId])
  @@index([clusterId])
  @@index([isPillar])
  @@index([deletedAt])
  @@map("topics")
}

model TopicCluster {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics Topic[]

  @@index([projectId])
  @@index([deletedAt])
  @@map("topic_clusters")
}

model TopicKeyword {
  id        String  @id @default(uuid())
  topicId   String
  keywordId String

  topic   Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([topicId, keywordId])
  @@index([topicId])
  @@index([keywordId])
  @@map("topic_keywords")
}

model TopicRelation {
  id          String   @id @default(uuid())
  fromTopicId String
  toTopicId   String
  relationType String  @default("supports") // supports, contradicts, related
  label       String?

  fromTopic Topic @relation("FromTopic", fields: [fromTopicId], references: [id], onDelete: Cascade)
  toTopic   Topic @relation("ToTopic", fields: [toTopicId], references: [id], onDelete: Cascade)

  @@unique([fromTopicId, toTopicId, relationType])
  @@index([fromTopicId])
  @@index([toTopicId])
  @@map("topic_relations")
}

// ============================================================================
// Phase 3: AI Provider Layer
// ============================================================================

model AIProvider {
  id              String         @id @default(uuid())
  projectId       String
  name            String
  type            AIProviderType @default(OLLAMA)
  baseUrl         String
  apiKey          String? // encrypted at rest
  defaultModel    String?
  isActive        Boolean        @default(true)
  isDefault       Boolean        @default(false)
  maxTokens       Int            @default(4096)
  temperature     Float          @default(0.7)
  timeout         Int            @default(60000)
  retryAttempts   Int            @default(3)
  privacySettings String? // JSON
  costPerToken    Float          @default(0) // zero for local providers
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  callLogs AICallLog[]
  promptTemplates PromptTemplate[]

  @@index([projectId])
  @@index([type])
  @@index([isActive])
  @@index([deletedAt])
  @@map("ai_providers")
}

model AICallLog {
  id              String    @id @default(uuid())
  providerId      String
  projectId       String
  model           String
  promptTemplateId String?
  inputTokens     Int       @default(0)
  outputTokens    Int       @default(0)
  totalTokens     Int       @default(0)
  cost            Float     @default(0)
  durationMs      Int       @default(0)
  success         Boolean   @default(true)
  errorMessage    String?
  purpose         String? // brief, draft, quality, intent, etc.
  createdAt       DateTime  @default(now())

  provider      AIProvider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  promptTemplate PromptTemplate? @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)

  @@index([providerId])
  @@index([projectId])
  @@index([purpose])
  @@index([createdAt])
  @@map("ai_call_logs")
}

model PromptTemplate {
  id          String   @id @default(uuid())
  providerId  String
  name        String
  description String?
  template    String
  version     String   @default("1.0")
  variables   String? // JSON array of variable names
  category    String? // brief, draft, quality, intent, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider AIProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  callLogs AICallLog[]

  @@unique([providerId, name, version])
  @@index([providerId])
  @@index([category])
  @@index([isActive])
  @@map("prompt_templates")
}

// ============================================================================
// Phase 3: Content Briefs & Studio
