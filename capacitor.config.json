{
  "appId": "nl.seocoach.app",
  "appName": "SEOCoach",
  "webDir": "out",
  "server": {
    "url": "https://seocoach.vercel.app",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0f172a"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f172a",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f172a"
    }
  }
}
