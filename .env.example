# ============================================================================
# SEOCoach — Volledige Productie Environment Configuration
# ============================================================================
# Kopieer dit bestand naar .env en vul ALLE waarden in:
#   cp .env.example .env
#
# Legenda:
#   VEREIST    = Applicatie start niet zonder deze variabele
#   AANBEVOLEN = Belangrijk voor productie, maar applicatie start wel
#   OPTIONEEL  = Alleen invullen als je de betreffende integratie gebruikt
# ============================================================================

# ============================================================================
# 1. CORE — Vereist
# ============================================================================

# ──────────────────────────────────────────────
# 1a. Database
# ──────────────────────────────────────────────
# Ontwikkeling: SQLite (lokaal bestand)
DATABASE_URL="file:./db/custom.db"

# Productie: PostgreSQL
# DATABASE_URL="postgresql://seocoach:JOUW_WACHTWOORD@localhost:5432/seocoach?schema=public&connection_limit=20&pool_timeout=10"
#
# PostgreSQL-database aanmaken:
#   sudo -u postgres psql
#   CREATE USER seocoach WITH PASSWORD 'JOUW_WACHTWOORD';
#   CREATE DATABASE seocoach OWNER seocoach;
#   GRANT ALL PRIVILEGES ON DATABASE seocoach TO seocoach;

# ──────────────────────────────────────────────
# 1b. NextAuth.js — Authenticatie & Sessies
# ──────────────────────────────────────────────
# Genereer een veilige secret:
#   openssl rand -base64 32
#   → plak de output hieronder
NEXTAUTH_SECRET="PLAK_HIER_JE_GENEREERDE_SECRET"

# Volledige URL waarop de applicatie bereikbaar is
# Ontwikkeling:
NEXTAUTH_URL="http://localhost:3000"
# Productie:
# NEXTAUTH_URL="https://seocoach.jouwdomein.nl"

# ============================================================================
# 2. E-MAIL — Aanbevolen voor productie
# ============================================================================
# Zonder SMTP-instellingen wordt er een lokale e-mailpreview gebruikt.
# In productie MOET je SMTP configureren voor:
#   - E-mailverificatie bij registratie
#   - Wachtwoord-reset e-mails
#   - Uitnodigingen voor organisaties
#   - Notificaties

SMTP_HOST="smtp.jouw-provider.nl"
SMTP_PORT="587"
SMTP_USER="noreply@jouwdomein.nl"
SMTP_PASS="JOUW_SMTP_WACHTWOORD"
SMTP_FROM="SEOCoach <noreply@jouwdomein.nl>"

# Veelgebruikte SMTP-servers:
#   TransIP:    smtp.transip.email    poort 587
#   Gmail:      smtp.gmail.com        poort 587  (met App Password)
#   Office365:  smtp.office365.com    poort 587
#   SendGrid:   smtp.sendgrid.net     poort 587  (gebruik "apikey" als user)
#   Mailgun:    smtp.mailgun.org      poort 587

# ============================================================================
# 3. GOOGLE OAUTH — Optioneel (voor GSC/GA4/GBP-integraties)
# ============================================================================
# Vereist voor automatische synchronisatie met:
#   - Google Search Console
#   - Google Analytics 4
#   - Google Business Profile
#
# Zonder deze variabelen werkt CSV-import nog steeds.
#
# Instellen:
#   1. Ga naar https://console.cloud.google.com/
#   2. Maak een project aan (bijv. "SEOCoach")
#   3. Ga naar API's & Services → Bibliotheek → Schakel in:
#      - Google Search Console API
#      - Google Analytics Data API (v1beta)
#      - Google Analytics Admin API (v1beta)
#      - Google Business Profile API
#      - Google Business Information API
#   4. Ga naar API's & Services → OAuth-toestemmingsscherm:
#      - Gebruikerstype: Extern
#      - Voeg scopes toe: webmasters.readonly, analytics.readonly, business.manage
#      - Publiceer de app (of voeg testgebruikers toe)
#   5. Ga naar API's & Services → Credentials → Credentials aanmaken
#      - Type: OAuth 2.0-client-id
#      - Toepassingstype: Webtoepassing
#      - Geautoriseerde omleidings-URL's:
#        https://jouwdomein.nl/api/google/oauth/callback
#        http://localhost:3000/api/google/oauth/callback  (voor ontwikkeling)
#   6. Kopieer Client ID en Client Secret hieronder

GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================================
# 4. AI-PROVIDERS — Optioneel (via UI geconfigureerd)
# ============================================================================
# AI-providers worden NIET in .env geconfigureerd, maar via de UI:
#   Project → AI-providers → Provider toevoegen
#
# Ondersteunde types:
#   ┌──────────────────────┬──────────────────────────────────┬──────────────┐
#   │ Type                 │ Base URL                         │ API Key      │
#   ├──────────────────────┼──────────────────────────────────┼──────────────┤
#   │ Ollama (lokaal)      │ http://localhost:11434           │ (leeg)       │
#   │ OpenAI               │ https://api.openai.com/v1        │ sk-...       │
#   │ Anthropic            │ https://api.anthropic.com/v1     │ sk-ant-...   │
#   │ DeepSeek             │ https://api.deepseek.com/v1      │ sk-...       │
#   │ Groq                 │ https://api.groq.com/openai/v1   │ gsk_...      │
#   │ OpenRouter           │ https://openrouter.ai/api/v1     │ sk-or-...    │
#   │ LM Studio (lokaal)   │ http://localhost:1234/v1         │ (leeg)       │
#   │ vLLM (lokaal)        │ http://localhost:8000/v1         │ (leeg)       │
#   │ Custom               │ (jouw URL)                       │ (jouw key)   │
#   └──────────────────────┴──────────────────────────────────┴──────────────┘
#
# API-keys bemachtigen:
#   OpenAI:     https://platform.openai.com/api-keys
#   Anthropic:  https://console.anthropic.com/ → Settings → API Keys
#   DeepSeek:   https://platform.deepseek.com/api_keys
#   Groq:       https://console.groq.com/keys
#   OpenRouter: https://openrouter.ai/keys

# Ollama installeren (aanbevolen, lokaal, gratis):
#   curl -fsSL https://ollama.com/install.sh | sh
#   ollama serve &
#   ollama pull llama3.1

# ============================================================================
# 5. CMS-INTEGRATIES — Optioneel (via UI geconfigureerd)
# ============================================================================
# CMS-verbindingen worden NIET in .env geconfigureerd, maar via de UI:
#   Project → CMS → Verbinding toevoegen
#
# WordPress:
#   Base URL:              https://jouwsite.nl
#   Gebruikersnaam:        jouw-wp-admin-gebruiker
#   Toepassingswachtwoord: WP Admin → Gebruikers → Profiel →
#                          Nieuw toepassingswachtwoord → "SEOCoach"
#
# WooCommerce:
#   Base URL:       https://jouwshop.nl
#   Consumer Key:   WP Admin → WooCommerce → Instellingen →
#                   Geavanceerd → REST API → Sleutel toevoegen
#                   Rechten: Lezen/Schrijven
#   Consumer Secret: (zelfde pagina, wordt samen getoond)
#
# Shopify:
#   Shop URL:       jouwshop.myshopify.com
#   Access Token:   Shopify Admin → Apps → Ontwikkel apps →
#                   API-rechten → Access Token

# ============================================================================
# 6. PM-INTEGRATIES — Optioneel (via UI geconfigureerd)
# ============================================================================
# Projectmanagement-verbindingen worden NIET in .env geconfigureerd,
# maar via de UI: Organisatie → PM-integraties
#
# ┌───────────────┬───────────────────────────────────────────────┬──────────────────────────────────────┐
# │ Provider      │ API Endpoint                                  │ Key bemachtigen                      │
# ├───────────────┼───────────────────────────────────────────────┼──────────────────────────────────────┤
# │ Jira          │ https://jouw.atlassian.net                    │ id.atlassian.com → API-tokens        │
# │ Trello        │ https://api.trello.com/1                      │ trello.com/app-key                   │
# │ Asana         │ https://app.asana.com/api/1.0                 │ Profiel → Apps → Developer App       │
# │ ClickUp       │ https://api.clickup.com/v2                    │ Instellingen → Apps → API Token      │
# │ Monday.com    │ https://api.monday.com/v2                     │ Profiel → Admin → API                │
# │ Linear        │ https://api.linear.app/graphql                │ Instellingen → API                   │
# │ GitHub Issues │ https://api.github.com                        │ github.com/settings/tokens           │
# │ Generic       │ (jouw webhook-URL)                            │ (geen key nodig)                     │
# └───────────────┴───────────────────────────────────────────────┴──────────────────────────────────────┘

# ============================================================================
# 7. REVIEW-BRONNEN — Optioneel (via UI geconfigureerd)
# ============================================================================
# Reviews kunnen geïmporteerd worden via CSV of via de UI:
#   Project → Reviews → Importeren
#
# Ondersteunde bronnen:
#   Google, WooCommerce, Trustpilot, CSV, Enquête,
#   Klantenservice-feedback, Handmatig

# ============================================================================
# 8. PRODUCT FEEDS — Optioneel (via UI geconfigureerd)
# ============================================================================
# Product feeds (XML/CSV) kunnen geïmporteerd worden via:
#   Project → Feeds → Feed toevoegen

# ============================================================================
# 9. APPLICATION SERVER — Optioneel
# ============================================================================
# Poort waarop de applicatie draait (standaard: 3000)
PORT="3000"

# Node.js omgeving
NODE_ENV="production"

# ============================================================================
# 10. BEVEILIGING — Aanbevolen voor productie
# ============================================================================
# Rate limiting voor authenticatie-endpoints (aantal pogingen per minuut)
# AUTH_RATE_LIMIT="10"

# Sessieduur in seconden (standaard: 86400 = 24 uur)
# AUTH_SESSION_MAX_AGE="86400"

# ============================================================================
# EINDE CONFIGURATIE
# ============================================================================
# Na het wijzigen van .env: herstart de applicatie!
#   bun run dev          (ontwikkeling)
#   bun run build && bun run start   (productie)
# ============================================================================
