# ============================================================================
# SEOCoach — Environment Configuration
# ============================================================================
# Kopieer dit bestand naar .env en vul de waarden in:
#   cp .env.example .env
# ============================================================================

# ──────────────────────────────────────────────
# VEREIST — Basisconfiguratie
# ──────────────────────────────────────────────

# Database (SQLite voor ontwikkeling, PostgreSQL voor productie)
DATABASE_URL="file:./db/custom.db"
# PRODUCTIE: DATABASE_URL="postgresql://gebruiker:wachtwoord@localhost:5432/seocoach"

# NextAuth.js — genereer een veilige secret met: openssl rand -base64 32
NEXTAUTH_SECRET="verander-deze-naar-een-veilige-willekeurige-string"

# Basis-URL van de applicatie
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# OPTIONEEL — E-mail (SMTP) voor productie
# ──────────────────────────────────────────────
# In ontwikkeling wordt een lokale e-mailpreview gebruikt.
# Voor productie configureer je SMTP:
# SMTP_HOST="smtp.jouw-provider.nl"
# SMTP_PORT="587"
# SMTP_USER="noreply@jouwdomein.nl"
# SMTP_PASS="jouw-smtp-wachtwoord"
# SMTP_FROM="SEOCoach <noreply@jouwdomein.nl>"

# ──────────────────────────────────────────────
# OPTIONEEL — Google OAuth (voor GSC/GA4/GBP)
# ──────────────────────────────────────────────
# GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-xxxxx"

# ──────────────────────────────────────────────
# AI-providers worden via de UI geconfigureerd
# (Project → AI-providers), niet in .env
# ──────────────────────────────────────────────
